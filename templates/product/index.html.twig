{% extends 'admin/layout.html.twig' %}
{% import '_macros.html.twig' as mac %}
{% block title %}Produits{% endblock %}
{% block breadcrumb %}Stock / Produits{% endblock %}

{% block content %}
{{ mac.flash_messages() }}
<div class="page-header">
    <div>
        <h1 class="page-title">Produits</h1>
        <p class="page-subtitle">{{ total }} produit(s) référencé(s).</p>
    </div>
    <a href="{{ path('product_new') }}" class="btn-apex btn-apex-primary"><i class="bi bi-plus-lg"></i> Nouveau produit</a>
</div>

<div class="apex-card">
    <div class="apex-card-header">
        <form method="get" style="display:flex;gap:8px;align-items:center;">
            <div class="search-input-wrapper"><i class="bi bi-search"></i><input type="text" name="search" value="{{ search }}" placeholder="Référence, désignation..."></div>
            <button type="submit" class="btn-apex btn-apex-outline"><i class="bi bi-search"></i></button>
            {% if search %}<a href="{{ path('product_index') }}" class="btn-apex btn-apex-outline"><i class="bi bi-x"></i></a>{% endif %}
        </form>
    </div>
    <div style="overflow-x:auto;">
        <table class="apex-table">
            <thead><tr>
                <th>Référence</th><th>Désignation</th><th>Famille</th><th>Déposant</th><th>Statut</th><th>UL liées</th><th style="text-align:right;">Actions</th>
            </tr></thead>
            <tbody>
            {% for product in products %}
            <tr>
                <td><span style="font-weight:600;font-family:monospace;">{{ product.reference }}</span></td>
                <td>{{ product.designation }}</td>
                <td style="color:var(--text-muted);font-size:12px;">{{ product.famille ?? '—' }}</td>
                <td style="color:var(--text-muted);font-size:12px;">{{ product.deposant ?? '—' }}</td>
                <td style="color:var(--text-muted);font-size:12px;">{{ product.statut ?? '—' }}</td>
                <td><span style="background:#ede9fe;color:#7c3aed;padding:2px 8px;border-radius:12px;font-size:12px;font-weight:600;">{{ product.charges|length }}</span></td>
                <td style="text-align:right;">
                    <div style="display:flex;gap:4px;justify-content:flex-end;">
                        <a href="{{ path('product_show', {id: product.id}) }}" class="action-btn" title="Voir"><i class="bi bi-eye"></i></a>
                        <a href="{{ path('product_edit', {id: product.id}) }}" class="action-btn" title="Modifier"><i class="bi bi-pencil"></i></a>
                        <button class="action-btn danger" data-bs-toggle="modal" data-bs-target="#deleteModal{{ product.id }}" title="Supprimer"><i class="bi bi-trash"></i></button>
                    </div>
                    {{ mac.delete_modal(product.id, product.reference, path('product_delete', {id: product.id}), csrf_token('delete'~product.id)) }}
                </td>
            </tr>
            {% else %}
            <tr><td colspan="7" style="text-align:center;padding:48px;color:var(--text-muted);"><i class="bi bi-upc-scan" style="font-size:32px;display:block;margin-bottom:8px;"></i>Aucun produit trouvé.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    {{ mac.pagination(page, pages, total, limit, 'product_index', {search: search}) }}
</div>
{% endblock %}
