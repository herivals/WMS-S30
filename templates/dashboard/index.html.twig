{% extends 'base.html.twig' %}

{% block title %}Tableau de bord — WMS-S30{% endblock %}

{% block body %}
<nav class="navbar navbar-dark bg-dark px-4">
    <span class="navbar-brand">WMS-S30</span>
    <div class="d-flex align-items-center gap-3">
        <span class="text-white">{{ app.user.email }}</span>
        {% if app.user.googleAuthenticatorEnabled %}
            <a href="{{ path('app_2fa_disable') }}" class="btn btn-sm btn-outline-warning">Désactiver 2FA</a>
        {% else %}
            <a href="{{ path('app_2fa_enable') }}" class="btn btn-sm btn-outline-success">Activer 2FA</a>
        {% endif %}
        <a href="{{ path('app_logout') }}" class="btn btn-sm btn-outline-light">Déconnexion</a>
    </div>
</nav>
<div class="container py-5">
    <h2>Bienvenue, {{ app.user.email }}</h2>
    <p class="text-muted">Vous êtes connecté au WMS-S30.</p>
    <div class="alert alert-{{ app.user.googleAuthenticatorEnabled ? 'success' : 'warning' }}">
        2FA : {{ app.user.googleAuthenticatorEnabled ? 'Activé' : 'Non activé — cliquez sur "Activer 2FA" pour sécuriser votre compte.' }}
    </div>
</div>
{% endblock %}
