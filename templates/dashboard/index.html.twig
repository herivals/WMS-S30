{% extends 'admin/layout.html.twig' %}

{% block title %}Tableau de bord{% endblock %}
{% block breadcrumb %}Tableau de bord{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <h1 class="page-title">Tableau de bord</h1>
        <p class="page-subtitle">Bienvenue, {{ app.user.displayName }}.</p>
    </div>
</div>

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-bottom:24px;">
    <div class="apex-card" style="padding:20px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
            <span style="font-size:13px;color:var(--text-muted);font-weight:500;">Total utilisateurs</span>
            <div style="width:36px;height:36px;background:#ede9fe;border-radius:8px;display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-people" style="color:#7c3aed;"></i>
            </div>
        </div>
        <div style="font-size:28px;font-weight:700;">—</div>
        <div style="font-size:12px;color:var(--text-muted);margin-top:4px;">
            <a href="{{ path('admin_user_index') }}" style="color:var(--accent);text-decoration:none;">Gérer les utilisateurs →</a>
        </div>
    </div>

    <div class="apex-card" style="padding:20px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
            <span style="font-size:13px;color:var(--text-muted);font-weight:500;">Sécurité 2FA</span>
            <div style="width:36px;height:36px;background:{{ app.user.googleAuthenticatorEnabled ? '#dcfce7' : '#fee2e2' }};border-radius:8px;display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-shield-{{ app.user.googleAuthenticatorEnabled ? 'fill-check' : 'x' }}"
                   style="color:{{ app.user.googleAuthenticatorEnabled ? '#16a34a' : '#dc2626' }};"></i>
            </div>
        </div>
        <div style="font-size:16px;font-weight:700;">
            {{ app.user.googleAuthenticatorEnabled ? 'Activé' : 'Non activé' }}
        </div>
        <div style="font-size:12px;color:var(--text-muted);margin-top:4px;">
            <a href="{{ path('app_2fa_enable') }}" style="color:var(--accent);text-decoration:none;">
                {{ app.user.googleAuthenticatorEnabled ? 'Gérer le 2FA →' : 'Activer le 2FA →' }}
            </a>
        </div>
    </div>
</div>
{% endblock %}
