{{ form_start(form) }}
<div class="apex-card" style="margin-bottom:16px;">
    <div class="apex-card-header"><span style="font-weight:600;font-size:14px;"><i class="bi bi-truck" style="margin-right:6px;"></i>Informations réception</span></div>
    <div style="padding:24px;display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div class="apex-form-group" style="grid-column:1/-1;">
            {{ form_label(form.reference, null, {label_attr: {class: 'apex-label'}}) }}
            {{ form_widget(form.reference, {attr: {class: 'apex-input'}}) }}{{ form_errors(form.reference) }}
        </div>
        <div class="apex-form-group">
            {{ form_label(form.date, null, {label_attr: {class: 'apex-label'}}) }}
            {{ form_widget(form.date, {attr: {class: 'apex-input'}}) }}{{ form_errors(form.date) }}
        </div>
        <div class="apex-form-group">
            {{ form_label(form.typeReception, null, {label_attr: {class: 'apex-label'}}) }}
            {{ form_widget(form.typeReception, {attr: {class: 'apex-input'}}) }}{{ form_errors(form.typeReception) }}
        </div>
    </div>
</div>
<div style="display:flex;gap:12px;">
    <button type="submit" class="btn-apex btn-apex-primary"><i class="bi bi-check-lg"></i> Enregistrer</button>
    <a href="{{ path('reception_index') }}" class="btn-apex btn-apex-outline">Annuler</a>
</div>
{{ form_end(form) }}
